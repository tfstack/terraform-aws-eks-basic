# Copy to terraform.tfvars and set your values.
# Add terraform.tfvars to .gitignore if it contains account-specific data.

# Cluster access: grant EKS cluster access to IAM principals via access_entries.
# Without this (or enable_cluster_creator_admin_permissions), you will not have kubectl access.
access_entries = {
  # Full cluster admin (e.g. for the Terraform runner or your admin role)
  admin = {
    principal_arn = "arn:aws:iam::ACCOUNT_ID:role/ROLE_NAME"
    type          = "STANDARD"
    policy_associations = {
      admin = {
        policy_arn   = "arn:aws:eks::aws:cluster-access-policy/AmazonEKSClusterAdminPolicy"
        access_scope = { type = "cluster" }
      }
    }
  }

  # Optional: read-only access (e.g. for viewers)
  # viewer = {
  #   principal_arn = "arn:aws:iam::ACCOUNT_ID:role/ViewerRole"
  #   type          = "STANDARD"
  #   policy_associations = {
  #     view = {
  #       policy_arn   = "arn:aws:eks::aws:cluster-access-policy/AmazonEKSViewPolicy"
  #       access_scope = { type = "cluster" }
  #     }
  #   }
  # }

  # Optional: namespace-scoped access (e.g. dev team in default namespace)
  # dev_default = {
  #   principal_arn = "arn:aws:iam::ACCOUNT_ID:role/DevTeamRole"
  #   type          = "STANDARD"
  #   policy_associations = {
  #     edit = {
  #       policy_arn   = "arn:aws:eks::aws:cluster-access-policy/AmazonEKSEditPolicy"
  #       access_scope = { type = "namespace", namespaces = ["default"] }
  #     }
  #   }
  # }
}

# ── Headlamp / SAML — Microsoft Entra or IAM Identity Center (optional) ────
# headlamp_hostnames = ["headlamp.example.com"]
# See examples/auto-mode/README.md. Typical Entra:
# headlamp_saml_metadata_url   = "https://login.microsoftonline.com/<tenant>/federationmetadata/2007-06/..."
# headlamp_saml_provider_name  = "AzureAD"
# headlamp_rbac_group_rules = [
#   { directory_group = "Your-Entra-Group", k8s_group = "platform-admins" },
# ]
# WAF logging (optional): bucket name must start with aws-waf-logs- for regional ACLs. Omit or null to skip logging.
# headlamp_waf_log_s3_bucket_name = "aws-waf-logs-myorg-dev"
